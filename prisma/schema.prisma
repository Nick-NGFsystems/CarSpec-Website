generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id        String   @id @default(cuid())
  make      String
  model     String
  year      Int
  trim      String?
  cylinders    Int?
  displacement Float?
  horsepower   Int?
  torque       Int?
  zeroToSixty  Float?
  drivetrain     String?
  transmission   String?
  fuelType       String?
  cityMpg     Int?
  highwayMpg  Int?
  combinedMpg Int?
  bodyStyle   String?
  doors       Int?
  seats       Int?
  curbWeight  Int?
  msrp        Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([make, model, year, trim])
  @@index([make])
  @@index([year])
  @@index([horsepower])
  @@index([drivetrain])
  @@index([bodyStyle])
  @@index([fuelType])
}