generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id        String   @id @default(cuid())
  make      String
  model     String
  year      Int
  trim      String?

  // Engine & Performance
  cylinders    Int?
  displacement Float?    // liters
  horsepower   Int?
  torque       Int?       // lb-ft
  zeroToSixty  Float?     // seconds

  // Drivetrain
  drivetrain     String?   // FWD, RWD, AWD, 4WD
  transmission   String?   // automatic, manual, CVT
  fuelType       String?   // gasoline, diesel, electric, hybrid

  // Economy
  cityMpg     Int?
  highwayMpg  Int?
  combinedMpg Int?

  // Body
  bodyStyle   String?    // sedan, SUV, truck, coupe, hatchback, wagon, convertible
  doors       Int?
  seats       Int?
  curbWeight  Int?       // lbs

  // Pricing
  msrp        Int?       // base MSRP in USD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([make, model, year, trim])
  @@index([make])
  @@index([year])
  @@index([horsepower])
  @@index([drivetrain])
  @@index([bodyStyle])
  @@index([fuelType])
}
